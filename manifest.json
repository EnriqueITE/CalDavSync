{
  "manifest_version": 2,
  "name": "Local Calendar CalDAV Mirror",
  "description": "Replicates a local Thunderbird calendar to a CalDAV collection without configuring that CalDAV calendar in Thunderbird.",
  "version": "0.1.0",
  "author": "Codex",
  "browser_specific_settings": {
    "gecko": {
      "id": "local-caldav-mirror@example.invalid",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "alarms",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "src/caldav.js",
      "src/sync-engine.js",
      "src/background.js"
    ]
  },
  "browser_action": {
    "default_title": "Local Calendar CalDAV Mirror",
    "default_popup": "ui/popup.html"
  },
  "options_ui": {
    "page": "ui/options.html",
    "open_in_tab": true
  },
  "experiment_apis": {
    "localCalendarMirror": {
      "schema": "api/localCalendarMirror/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["localCalendarMirror"]],
        "script": "api/localCalendarMirror/implementation.js"
      }
    }
  }
}
