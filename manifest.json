{
  "manifest_version": 2,
  "name": "CalDavSync",
  "description": "Mirrors a local Thunderbird calendar to a private CalDAV collection without configuring the remote calendar in Thunderbird.",
  "version": "0.2.8",
  "author": "Codex",
  "browser_specific_settings": {
    "gecko": {
      "id": "caldavsync@example.invalid",
      "strict_min_version": "128.0"
    }
  },
  "permissions": [
    "alarms",
    "storage",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "src/secrets.js",
      "src/caldav.js",
      "src/sync-engine.js",
      "src/background.js"
    ]
  },
  "browser_action": {
    "default_title": "CalDavSync",
    "default_popup": "ui/popup.html"
  },
  "options_ui": {
    "page": "ui/options.html",
    "open_in_tab": true
  },
  "experiment_apis": {
    "CalDavSync": {
      "schema": "api/localCalendarMirror/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["CalDavSync"]],
        "script": "api/localCalendarMirror/implementation.js",
        "events": ["startup"]
      }
    }
  }
}
